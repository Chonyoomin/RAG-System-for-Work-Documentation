# Copy to .env and fill in real values locally. Never commit .env.

# LLM (optional for early prototype; only needed once answer generation is wired up)
OPENAI_API_KEY=

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/documentation_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=documentation_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Embeddings (local model by default — no API key required)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Upload storage (defaults to <repo_root>/data/uploads — must stay git-ignored)
UPLOAD_DIR=
MAX_UPLOAD_BYTES=26214400
